# ════════════════════════════════════════════════════
# InstaShift – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control!
# ════════════════════════════════════════════════════

# ── Discord ──────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: restrict slash-command registration to one guild during development.
# Leave empty (or remove) for global registration in production.
GUILD_ID=

# ── Instagram ─────────────────────────────────────────
# Public Instagram account used to scrape feeds.
# The bot works in "guest" mode first; these creds are used for
# authenticated requests (higher rate limits, Stories support).
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# ── Database ──────────────────────────────────────────
# SQLite database file path (relative to project root).
DB_PATH=instashift.db

# ── Session ───────────────────────────────────────────
# Path where the Instagram session JSON is persisted.
SESSION_PATH=ig_session.json

# ── Polling ───────────────────────────────────────────
# How often (in minutes) the feed-checker task runs.
CHECK_INTERVAL=10

# ── Logging ───────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
